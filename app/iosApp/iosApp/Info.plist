<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>将棋サプリ</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- ComposeUIViewController の起動時サニティチェックが要求するキー。
	     高リフレッシュレートiPhoneでの描画性能低下を防ぐ（Compose Multiplatform公式ドキュメント推奨）。
	     GENERATE_INFOPLIST_FILE の INFOPLIST_KEY_ 機構は既知キーのみ対応のため、
	     このキーは実ファイルとして持つ必要がある。 -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!-- 輸出コンプライアンス: 使用する暗号化はHTTPS（Supabase/Sentry通信）のみで
	     免除対象。このキーを持たないとTestFlightアップロードごとにApp Store Connectで
	     暗号化質問への回答が必要になるため、ビルドに埋め込んで恒久化する。 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
